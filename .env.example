# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...          # Used by the frontend (Lovable)
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Used by the Mastra agent (server-side only — keep secret)
# From: Supabase Dashboard → Settings → Database → Session Pooler connection string
# Host: aws-1-us-east-2.pooler.supabase.com  Port: 5432  User: postgres.<project-ref>
SUPABASE_DB_PASSWORD=your-db-password  # E2B sandboxes connect via psycopg2 session pooler (IPv4)

# ─── E2B ──────────────────────────────────────────────────────────────────────
# From: e2b.dev → Dashboard → API Keys
E2B_API_KEY=e2b_...

# ─── Mastra Platform ──────────────────────────────────────────────────────────
# Set automatically by Mastra Platform when deploying via GitHub.
# Only needed if self-hosting.
# MASTRA_API_KEY=...

# ─── App URL (for CORS) ───────────────────────────────────────────────────────
# The Lovable app URL — set in Mastra Platform env vars for CORS configuration.
ALLOWED_ORIGIN=https://your-app.lovable.app
